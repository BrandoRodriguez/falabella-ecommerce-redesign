---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Icon from "@/components/ui/icons.astro";

interface ImageProps {
  desktop: ImageMetadata;
  mobile: ImageMetadata;
  alt: string;
  heightMobile: string;
}

interface Props {
  image: ImageProps;
  name: string;
  description: string;
  slug: string;
  icons: string[];
}

const { image, slug, name, description, icons } = Astro.props as Props;
---

<a href={slug} target="_blank" rel="noopener noreferrer" class="card-link">
  <div class="card">
    <div class="card-images">
      <Image
        src={image.desktop}
        alt={image.alt}
        class="image-desktop"
        densities={[1, 1.5, 2]}
        loading="lazy"
      />

      <div class="image-mobile-wrapper" style={`height:${image.heightMobile}`}>
        <Image
          src={image.mobile}
          alt={image.alt}
          class="image-mobile"
          densities={[1, 1.5, 2]}
          loading="lazy"
        />
      </div>
    </div>
    <div class="card-details">
      <h3>{name}</h3>

      <div>
        {icons.map((item) => <Icon name={item} />)}
        <Icon name="arrow-right" />
        <small>{description}</small>
      </div>
    </div>
  </div>
</a>

<style>
  .card {
    block-size: 100%;
    border-radius: 0.75rem;
    overflow: hidden;
    background: hsl(var(--card));
  }

  .card-images {
    position: relative;
    overflow: hidden;
  }

  .card-details {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-details div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .image-desktop {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: 0 -2px;
    transform: scale(1.05);
    padding-block-start: 0.5rem;
    aspect-ratio: 1 / 1.11;
  }

  .image-mobile-wrapper {
    position: absolute;
    inset-block-end: 0;
    inset-inline-end: 0.25rem;
    inline-size: 120px;
  }

  .image-mobile {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: 0 -3px;
    border-block-start: 1px solid hsl(var(--card));
    border-inline-start: 1px solid hsl(var(--card));
    border-inline-end: 1px solid hsl(var(--card));
    border-start-start-radius: 0.75rem;
    border-start-end-radius: 0.75rem;
  }
</style>
